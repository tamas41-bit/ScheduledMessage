<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#888888"
        android:ellipsize="end"
        android:singleLine="true"
        android:layout_marginBottom="20dp" />

    <!-- 딜레이 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="알림 시작 후 몇 초 뒤에 표시할까요?"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <EditText
            android:id="@+id/etDelaySeconds"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:inputType="number"
            android:gravity="center"
            android:textSize="28sp"
            android:hint="0"
            android:textColorHint="#666666" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" 초 후"
            android:textSize="18sp"
            android:textColor="#CCCCCC"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#333333" android:layout_marginBottom="20dp"/>

    <!-- 프로필 사진 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="프로필 사진"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/ivMsgIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:clipToOutline="true"
            android:background="@drawable/bg_card_icon"
            android:src="@drawable/ic_notification_icon" />

        <Button
            android:id="@+id/btnPickMsgIcon"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="변경"
            android:textSize="13sp"
            android:layout_marginStart="12dp"
            android:backgroundTint="#444444"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnClearMsgIcon"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="기본값"
            android:textSize="13sp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#333333"
            android:textColor="#AAAAAA"
            android:stateListAnimator="@null"/>

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#333333" android:layout_marginBottom="20dp"/>

    <!-- 글자색 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="글자색"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="10dp" />

    <!-- 색상 스와치 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="14dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/swatchDefault"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="기본"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:background="#2A2A2A"
                android:layout_marginEnd="8dp"/>

            <View android:id="@+id/swatchWhite"
                android:layout_width="44dp" android:layout_height="44dp"
                android:background="#F0F0F5" android:layout_marginEnd="8dp"/>

            <View android:id="@+id/swatchYellow"
                android:layout_width="44dp" android:layout_height="44dp"
                android:background="#FFE066" android:layout_marginEnd="8dp"/>

            <View android:id="@+id/swatchSky"
                android:layout_width="44dp" android:layout_height="44dp"
                android:background="#7EC8E3" android:layout_marginEnd="8dp"/>

            <View android:id="@+id/swatchGreen"
                android:layout_width="44dp" android:layout_height="44dp"
                android:background="#6BFF8A" android:layout_marginEnd="8dp"/>

            <View android:id="@+id/swatchPink"
                android:layout_width="44dp" android:layout_height="44dp"
                android:background="#FFB3C6" android:layout_marginEnd="8dp"/>

            <View android:id="@+id/swatchOrange"
                android:layout_width="44dp" android:layout_height="44dp"
                android:background="#FFAA55" android:layout_marginEnd="8dp"/>

            <View android:id="@+id/swatchRed"
                android:layout_width="44dp" android:layout_height="44dp"
                android:background="#FF4444"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- RGB 슬라이더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView android:layout_width="16dp" android:layout_height="wrap_content"
            android:text="R" android:textColor="#FF6B6B" android:textSize="13sp" android:textStyle="bold"/>
        <SeekBar android:id="@+id/seekColorR"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:layout_marginStart="8dp" android:layout_marginEnd="8dp"
            android:min="0" android:max="255" android:progress="240"
            android:progressTint="#FF6B6B" android:thumbTint="#FF6B6B"/>
        <TextView android:id="@+id/tvColorR" android:layout_width="32dp" android:layout_height="wrap_content"
            android:text="240" android:textColor="#99FFFFFF" android:textSize="12sp" android:gravity="end"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView android:layout_width="16dp" android:layout_height="wrap_content"
            android:text="G" android:textColor="#6BFF8A" android:textSize="13sp" android:textStyle="bold"/>
        <SeekBar android:id="@+id/seekColorG"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:layout_marginStart="8dp" android:layout_marginEnd="8dp"
            android:min="0" android:max="255" android:progress="240"
            android:progressTint="#6BFF8A" android:thumbTint="#6BFF8A"/>
        <TextView android:id="@+id/tvColorG" android:layout_width="32dp" android:layout_height="wrap_content"
            android:text="240" android:textColor="#99FFFFFF" android:textSize="12sp" android:gravity="end"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView android:layout_width="16dp" android:layout_height="wrap_content"
            android:text="B" android:textColor="#6B9FFF" android:textSize="13sp" android:textStyle="bold"/>
        <SeekBar android:id="@+id/seekColorB"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:layout_marginStart="8dp" android:layout_marginEnd="8dp"
            android:min="0" android:max="255" android:progress="245"
            android:progressTint="#6B9FFF" android:thumbTint="#6B9FFF"/>
        <TextView android:id="@+id/tvColorB" android:layout_width="32dp" android:layout_height="wrap_content"
            android:text="245" android:textColor="#99FFFFFF" android:textSize="12sp" android:gravity="end"/>
    </LinearLayout>

    <!-- 선택 색상 미리보기 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="선택: " android:textSize="13sp" android:textColor="#888888"/>
        <TextView android:id="@+id/tvSelectedColor"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="기본값" android:textSize="13sp" android:textColor="#AAAAAA"/>
        <View android:id="@+id/viewColorDot"
            android:layout_width="16dp" android:layout_height="16dp"
            android:layout_marginStart="8dp"
            android:background="#2A2A2A" android:visibility="invisible"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#333333" android:layout_marginBottom="20dp"/>

    <!-- 글자 스타일 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="글자 스타일"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="14dp" />

    <!-- 굵기 토글 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="굵게"
            android:textSize="15sp"
            android:textColor="#CCCCCC"/>

        <Switch
            android:id="@+id/switchTextBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- 글자 크기 슬라이더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="글자 크기"
            android:textSize="15sp"
            android:textColor="#CCCCCC"/>

        <TextView
            android:id="@+id/tvTextSizeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="기본(14sp)"
            android:textSize="13sp"
            android:textColor="#AAAAAA"/>
    </LinearLayout>

    <SeekBar
        android:id="@+id/seekTextSize"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:min="10"
        android:max="28"
        android:progress="14"
        android:progressTint="#FFFFFF"
        android:thumbTint="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnResetTextSize"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="크기 기본값"
        android:textSize="12sp"
        android:backgroundTint="#333333"
        android:textColor="#AAAAAA"
        android:stateListAnimator="@null"/>

</LinearLayout>
</ScrollView>
