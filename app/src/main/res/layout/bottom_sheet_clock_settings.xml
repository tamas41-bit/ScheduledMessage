<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1C1C1E"
    android:paddingBottom="32dp">

    <!-- 핸들 바 -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        android:background="#55FFFFFF"
        android:backgroundTint="#55FFFFFF"/>

    <!-- 제목 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="시계 설정"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp"/>

    <!-- 날짜 표시 토글 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="#2C2C2E">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="날짜 표시"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <Switch
            android:id="@+id/switchShowDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#3A3A3C"/>

    <!-- 시계 크기 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        android:background="#2C2C2E">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="시계 크기"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvSizeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="72sp"
                android:textColor="#99FFFFFF"
                android:textSize="14sp"/>
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekClockSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="24"
            android:max="150"
            android:progress="72"
            android:layout_marginTop="8dp"
            android:progressTint="#FFFFFF"
            android:thumbTint="#FFFFFF"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#3A3A3C"/>

    <!-- 폰트 선택 버튼 -->
    <LinearLayout
        android:id="@+id/rowFontSelect"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="#2C2C2E"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="폰트 선택"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tvCurrentFont"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="기본체"
            android:textColor="#99FFFFFF"
            android:textSize="14sp"
            android:layout_marginEnd="4dp"/>

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/arrow_up_float"
            android:rotation="90"
            android:alpha="0.5"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#3A3A3C"/>

    <!-- 시간 설정 버튼 -->
    <LinearLayout
        android:id="@+id/rowTimeEdit"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="#2C2C2E">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="시간 설정"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="실제 시간"
            android:textColor="#99FFFFFF"
            android:textSize="14sp"
            android:layout_marginEnd="4dp"/>

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/arrow_up_float"
            android:rotation="90"
            android:alpha="0.5"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#3A3A3C"/>

    <!-- 시작 대기 시간 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        android:background="#2C2C2E">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="시작 대기 시간"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvStartDelayLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3초"
                android:textColor="#99FFFFFF"
                android:textSize="14sp"/>
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekStartDelay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="0"
            android:max="60"
            android:progress="3"
            android:layout_marginTop="8dp"
            android:progressTint="#FFFFFF"
            android:thumbTint="#FFFFFF"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#3A3A3C"/>

    <!-- 알림 카드 색상 & 투명도 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="#2C2C2E">

        <!-- 섹션 제목 + 색상 미리보기 바 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="알림 카드 색상"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>

            <!-- 현재 색상 미리보기 박스 -->
            <View
                android:id="@+id/viewColorPreview"
                android:layout_width="48dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_swatch_color"
                android:backgroundTint="#232323"/>
        </LinearLayout>

        <!-- 대표 색상 스와치 8개 -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View android:id="@+id/swatch1"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_swatch_color"
                    android:backgroundTint="#232323"
                    android:clickable="true" android:focusable="true"/>

                <View android:id="@+id/swatch2"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_swatch_color"
                    android:backgroundTint="#0D0D0D"
                    android:clickable="true" android:focusable="true"/>

                <View android:id="@+id/swatch3"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_swatch_color"
                    android:backgroundTint="#0A1628"
                    android:clickable="true" android:focusable="true"/>

                <View android:id="@+id/swatch4"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_swatch_color"
                    android:backgroundTint="#1A0A3C"
                    android:clickable="true" android:focusable="true"/>

                <View android:id="@+id/swatch5"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_swatch_color"
                    android:backgroundTint="#0A2818"
                    android:clickable="true" android:focusable="true"/>

                <View android:id="@+id/swatch6"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_swatch_color"
                    android:backgroundTint="#3C0A0A"
                    android:clickable="true" android:focusable="true"/>

                <View android:id="@+id/swatch7"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_swatch_color"
                    android:backgroundTint="#0A2A2C"
                    android:clickable="true" android:focusable="true"/>

                <View android:id="@+id/swatch8"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:background="@drawable/bg_swatch_color"
                    android:backgroundTint="#2E1A06"
                    android:clickable="true" android:focusable="true"/>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- R 슬라이더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="16dp"
                android:layout_height="wrap_content"
                android:text="R"
                android:textColor="#FF6B6B"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <SeekBar
                android:id="@+id/seekR"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:min="0"
                android:max="255"
                android:progress="35"
                android:progressTint="#FF6B6B"
                android:thumbTint="#FF6B6B"/>

            <TextView
                android:id="@+id/tvR"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="35"
                android:textColor="#99FFFFFF"
                android:textSize="12sp"
                android:gravity="end"/>
        </LinearLayout>

        <!-- G 슬라이더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="16dp"
                android:layout_height="wrap_content"
                android:text="G"
                android:textColor="#6BFF8A"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <SeekBar
                android:id="@+id/seekG"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:min="0"
                android:max="255"
                android:progress="35"
                android:progressTint="#6BFF8A"
                android:thumbTint="#6BFF8A"/>

            <TextView
                android:id="@+id/tvG"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="35"
                android:textColor="#99FFFFFF"
                android:textSize="12sp"
                android:gravity="end"/>
        </LinearLayout>

        <!-- B 슬라이더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="16dp"
                android:layout_height="wrap_content"
                android:text="B"
                android:textColor="#6B9FFF"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <SeekBar
                android:id="@+id/seekB"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:min="0"
                android:max="255"
                android:progress="35"
                android:progressTint="#6B9FFF"
                android:thumbTint="#6B9FFF"/>

            <TextView
                android:id="@+id/tvB"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="35"
                android:textColor="#99FFFFFF"
                android:textSize="12sp"
                android:gravity="end"/>
        </LinearLayout>

        <!-- 투명도 슬라이더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="투명도"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvAlphaLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="72%"
                android:textColor="#99FFFFFF"
                android:textSize="14sp"/>
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekCardAlpha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="10"
            android:max="100"
            android:progress="72"
            android:layout_marginTop="8dp"
            android:progressTint="#FFFFFF"
            android:thumbTint="#FFFFFF"/>

        <!-- 미리보기 버튼 -->
        <Button
            android:id="@+id/btnPreview"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:text="미리보기"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#0A84FF"
            android:stateListAnimator="@null"/>

    </LinearLayout>

</LinearLayout>
