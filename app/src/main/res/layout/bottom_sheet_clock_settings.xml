<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1C1C1E"
    android:paddingBottom="32dp">

    <!-- 핸들 바 -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        android:background="#55FFFFFF"
        android:backgroundTint="#55FFFFFF"/>

    <!-- 제목 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="시계 설정"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp"/>

    <!-- 날짜 표시 토글 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="#2C2C2E">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="날짜 표시"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <Switch
            android:id="@+id/switchShowDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#3A3A3C"/>

    <!-- 시계 크기 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        android:background="#2C2C2E">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="시계 크기"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvSizeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="72sp"
                android:textColor="#99FFFFFF"
                android:textSize="14sp"/>
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekClockSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="24"
            android:max="150"
            android:progress="72"
            android:layout_marginTop="8dp"
            android:progressTint="#FFFFFF"
            android:thumbTint="#FFFFFF"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#3A3A3C"/>

    <!-- 폰트 선택 버튼 -->
    <LinearLayout
        android:id="@+id/rowFontSelect"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="#2C2C2E"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="폰트 선택"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tvCurrentFont"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="기본체"
            android:textColor="#99FFFFFF"
            android:textSize="14sp"
            android:layout_marginEnd="4dp"/>

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/arrow_up_float"
            android:rotation="90"
            android:alpha="0.5"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#3A3A3C"/>

    <!-- 시간 설정 버튼 -->
    <LinearLayout
        android:id="@+id/rowTimeEdit"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="#2C2C2E">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="시간 설정"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="실제 시간"
            android:textColor="#99FFFFFF"
            android:textSize="14sp"
            android:layout_marginEnd="4dp"/>

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/arrow_up_float"
            android:rotation="90"
            android:alpha="0.5"/>
    </LinearLayout>

</LinearLayout>
