<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1C1C1E"
    android:paddingBottom="32dp">

    <!-- 핸들 바 -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        android:background="#55FFFFFF"
        android:backgroundTint="#55FFFFFF"/>

    <!-- 제목 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="시계 설정"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp"/>

    <!-- 날짜 표시 토글 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="#2C2C2E">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="날짜 표시"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <Switch
            android:id="@+id/switchShowDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#3A3A3C"/>

    <!-- 시계 크기 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        android:background="#2C2C2E">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="시계 크기"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvSizeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="72sp"
                android:textColor="#99FFFFFF"
                android:textSize="14sp"/>
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekClockSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="24"
            android:max="150"
            android:progress="72"
            android:layout_marginTop="8dp"
            android:progressTint="#FFFFFF"
            android:thumbTint="#FFFFFF"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#3A3A3C"/>

    <!-- 폰트 선택 버튼 -->
    <LinearLayout
        android:id="@+id/rowFontSelect"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="#2C2C2E"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="폰트 선택"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tvCurrentFont"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="기본체"
            android:textColor="#99FFFFFF"
            android:textSize="14sp"
            android:layout_marginEnd="4dp"/>

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/arrow_up_float"
            android:rotation="90"
            android:alpha="0.5"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#3A3A3C"/>

    <!-- 시간 설정 버튼 -->
    <LinearLayout
        android:id="@+id/rowTimeEdit"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="#2C2C2E">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="시간 설정"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="실제 시간"
            android:textColor="#99FFFFFF"
            android:textSize="14sp"
            android:layout_marginEnd="4dp"/>

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/arrow_up_float"
            android:rotation="90"
            android:alpha="0.5"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#3A3A3C"/>

    <!-- 알림 카드 색상 & 투명도 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="#2C2C2E">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="알림 카드 색상"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <!-- 색상 스와치 행 -->
        <LinearLayout
            android:id="@+id/layoutSwatches"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout android:id="@+id/swatchGray" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="10dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_swatch_color" android:backgroundTint="#232323"/>
                <View android:id="@+id/ringGray" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_swatch_ring" android:visibility="gone"/>
            </FrameLayout>

            <FrameLayout android:id="@+id/swatchBlack" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="10dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_swatch_color" android:backgroundTint="#050505"/>
                <View android:id="@+id/ringBlack" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_swatch_ring" android:visibility="gone"/>
            </FrameLayout>

            <FrameLayout android:id="@+id/swatchBlue" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="10dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_swatch_color" android:backgroundTint="#1A2A3A"/>
                <View android:id="@+id/ringBlue" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_swatch_ring" android:visibility="gone"/>
            </FrameLayout>

            <FrameLayout android:id="@+id/swatchPurple" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="10dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_swatch_color" android:backgroundTint="#251E35"/>
                <View android:id="@+id/ringPurple" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_swatch_ring" android:visibility="gone"/>
            </FrameLayout>

            <FrameLayout android:id="@+id/swatchGreen" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="10dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_swatch_color" android:backgroundTint="#182E18"/>
                <View android:id="@+id/ringGreen" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_swatch_ring" android:visibility="gone"/>
            </FrameLayout>

            <FrameLayout android:id="@+id/swatchRed" android:layout_width="40dp" android:layout_height="40dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_swatch_color" android:backgroundTint="#301818"/>
                <View android:id="@+id/ringRed" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_swatch_ring" android:visibility="gone"/>
            </FrameLayout>

        </LinearLayout>

        <!-- 투명도 슬라이더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="18dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="투명도"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvAlphaLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="72%"
                android:textColor="#99FFFFFF"
                android:textSize="14sp"/>
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekCardAlpha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="10"
            android:max="100"
            android:progress="72"
            android:layout_marginTop="8dp"
            android:progressTint="#FFFFFF"
            android:thumbTint="#FFFFFF"/>

    </LinearLayout>

</LinearLayout>
